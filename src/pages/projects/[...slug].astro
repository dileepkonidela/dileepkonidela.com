---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const date = project.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${project.data.title} — Dileep Konidela`} description={project.data.description}>
  <div class="container">
    <header class="post-header">
      <h1>{project.data.title}</h1>
      <div class="post-meta">
        <span>{date}</span>
        {project.data.tech.map(t => <span class="tag">{t}</span>)}
      </div>
      <div class="project-card-links" style="margin-top: 1rem;">
        {project.data.url && <a href={project.data.url} target="_blank" rel="noopener">Live site ↗</a>}
        {project.data.github && <a href={project.data.github} target="_blank" rel="noopener">GitHub ↗</a>}
      </div>
    </header>
    <article class="prose">
      <Content />
    </article>
    <a href="/projects" class="back-link">← All projects</a>
  </div>
</BaseLayout>
