        <a href="https://twitter.com/dileepkonidela" target="_blank" rel="noopener">Twitter / X</a>
        <a href="mailto:dileep.kr90@gmail.com">dileep.kr90@gmail.com</a>
      </div>
    </div>
  </div>
</BaseLayout>
